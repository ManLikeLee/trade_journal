# ============================================================
# TradeJournal Backend — Environment Variables
# Copy this file to .env and fill in real values
# ============================================================

# Database — PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tradejournal?schema=public"

# JWT — use a long random string in production
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="92182e75d1ae79df852ba6d5452fdab50c9c5d5200f1491322a00a3f76ebe63154dcb6764e1d4ae57e13aad3c7ea7fe2da14b290359e4486fd433339ea8b288e"

# Frontend URL — used for CORS
FRONTEND_URL="http://localhost:3000"

# Server port
PORT=4000

# Node environment
NODE_ENV=development
